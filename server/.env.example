# Server
PORT=3000

# QPay credentials (QPay merchant dashboard-аас авна)
QPAY_USERNAME=your_qpay_username
QPAY_PASSWORD=your_qpay_password
QPAY_INVOICE_CODE=your_invoice_code
QPAY_BASE_URL=https://merchant.qpay.mn/v2

# Callback URL (deploy хийсний дараа бодит URL тавина)
CALLBACK_URL=http://localhost:3000/api/qpay/callback

# Email (захиалга ирэхэд мэдэгдэл илгээх)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=info@femmorabeauties.com
