{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**",
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/admin", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
